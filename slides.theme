<!DOCTYPE html>
<html>
<head>
  <meta name="generator" content=
  "HTML Tidy for Mac OS X (vers 31 October 2006 - Apple Inc. build 6834), see www.w3.org">
  <meta charset="utf-8">
  <meta name="viewport" content=
  "width=device-width, initial-scale=1.0, user-scalable=yes">

  <title><?theme title?></title>

  <style type="text/css">
  /* ---------------------------------------------------------------
     Design tokens
     --------------------------------------------------------------- */
  :root {
    --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                 Helvetica, Arial, sans-serif;
    --font-mono: "SFMono-Regular", Menlo, Consolas, "Liberation Mono",
                 monospace;

    --color-bg:          #fbfaf6;
    --color-surface:     #ffffff;
    --color-text:        #1c1c1a;
    --color-text-muted:  #6b6a62;
    --color-border:      #e4e0d4;

    --color-accent:        #0f7d78;
    --color-accent-strong: #0a5f5b;
    --color-accent-soft:   #e5f2f1;
    --color-amber:         #b9781f;

    --color-code-bg:  #f4f2ea;
    --color-inline-code-bg: #f0ede2;

    --radius-sm: 4px;
    --radius-md: 10px;

    --slide-width: 100%;
  }

  /* ---------------------------------------------------------------
     Syntax highlighting (Prism), tuned to the palette above
     --------------------------------------------------------------- */
  pre code {
    padding: 1em;
  }
  .token.comment {
    color: var(--color-text-muted);
    font-style: italic;
  }
  .token.punctuation {
    color: #9a978c;
  }
  .token.tag,
  .token.selector {
    color: #b34a68;
  }
  .token.boolean,
  .token.number,
  .token.constant,
  .token.symbol {
    color: #7a54c4;
  }
  .token.property,
  .token.attr-name,
  .token.string,
  .token.char,
  .token.builtin {
    color: var(--color-amber);
  }
  .token.inserted {
    background-color: #d8f0e3;
  }
  .token.deleted {
    background-color: #fbe3e1;
  }
  .token.operator,
  .token.entity,
  .token.url,
  .language-css .token.string,
  .style .token.string {
    color: #8a6d3b;
  }
  .token.atrule,
  .token.attr-value,
  .token.keyword {
    color: var(--color-accent-strong);
  }
  .token.function,
  .token.class-name {
    color: #b34a68;
  }
  .token.regex,
  .token.important,
  .token.variable {
    color: #7a54c4;
  }
  .token.important,
  .token.bold {
    font-weight: 700;
  }
  .token.italic {
    font-style: italic;
  }
  </style>

  <style type="text/css">
  /* ---------------------------------------------------------------
     Base document / markdown typography
     --------------------------------------------------------------- */
  *, *:before, *:after {
    box-sizing: border-box;
  }
  body {
    font-family: var(--font-sans);
    max-width: 800px;
    margin: auto;
    padding: 1em;
    line-height: 1.6;
    background-color: var(--color-bg);
    color: var(--color-text);
    -webkit-font-smoothing: antialiased;
  }
  body, .footnotes, code { font-size: .95em; }
  li li { font-size: .95em; }

  h1, h2, h3, h4 {
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
  h1 { letter-spacing: -0.02em; }

  pre, img {
    max-width: 100%;
    max-height: 90%;
    display: block;
    margin-left: auto;
    margin-right: auto;
  }
  img { border-radius: var(--radius-md); }
  pre, pre:hover {
    white-space: pre-wrap;
    word-break: break-all;
  }
  pre code {
    display: block;
    overflow-x: auto;
    background-color: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }
  code { font-family: var(--font-mono); }
  :not(pre) > code, code[class] {
    background-color: var(--color-inline-code-bg);
    padding: .15em .4em;
    border-radius: var(--radius-sm);
  }
  code.language-undefined, pre > code:not([class]) {
    background-color: var(--color-code-bg);
  }

  table {
    margin: auto;
    border-collapse: collapse;
    border-top: 2px solid var(--color-text);
  }
  table thead th {
    border-bottom: 1px solid var(--color-text);
    text-align: left;
  }
  th, td { padding: .4em .7em; }
  thead { background: var(--color-accent-soft); }
  tfoot, tr:nth-child(even) { background: rgba(15, 125, 120, 0.05); }

  blockquote {
    color: var(--color-text-muted);
    margin: 0;
    font-style: italic;
    padding: .3em 1em;
    border-left: 0.35em solid var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }
  hr, .footnotes::before { border: 1px dashed var(--color-border); }
  .frontmatter { text-align: center; }
  #TOC .numbered li { list-style: none; }
  #TOC .numbered { padding-left: 0; }
  #TOC .numbered ul { padding-left: 1em; }
  table, .body h2 { border-bottom: 1px solid var(--color-border); }
  .body .appendix, .appendix ~ h2 { border-bottom-style: dashed; }
  .footnote-ref a::before { content: "["; }
  .footnote-ref a::after { content: "]"; }
  section.footnotes::before {
    content: "";
    display: block;
    max-width: 20em;
  }

  @media print {
    body {
      font-size: 12pt;
      max-width: 100%;
    }
    tr, img { page-break-inside: avoid; }
  }
  @media only screen and (min-width: 992px) {
    pre { white-space: pre; }
  }
  </style>

  <style type="text/css">
  /* ---------------------------------------------------------------
     Slide layout & chrome
     --------------------------------------------------------------- */
  html { scroll-snap-type: y mandatory; }
  th, td { padding: .3em .6em; }
  .slide {
    padding: 1.4em;
    position: relative;
  }
  .slide > h2, .slide > h3 { margin-top: unset; }
  body {
    max-width: fit-content;
    padding: 0;
  }
  a {
    color: var(--color-accent-strong);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent-soft);
  }
  a:hover { border-bottom-color: var(--color-accent-strong); }
  :not(pre) > code { background-color: var(--color-inline-code-bg); }

  #TOC { columns: 2; }
  #TOC::before {
    content: "Contents";
    font-size: 1.3em;
    font-weight: 700;
    display: block;
    border-bottom: 2px solid var(--color-text);
    margin-bottom: .3em;
    padding-bottom: .2em;
  }

  .frontmatter, .middle {
    display: flex;
    justify-content: center;
    flex-direction: column;
  }

  .page-number, .timer {
    position: absolute;
    bottom: .6em;
    opacity: .55;
    font: .7em/1 var(--font-mono);
    color: var(--color-text-muted);
    background: var(--color-surface);
    padding: .15em .5em;
    border-radius: 999px;
    border: 1px solid var(--color-border);
  }
  .page-number { right: .6em; }
  .timer { left: .6em; }

  .inverse {
    background-color: #eee;
    filter: invert(1);
  }
  .fade {
    background: repeating-linear-gradient(135deg,
      var(--color-bg), var(--color-bg) 30px,
      var(--color-border) 32px, var(--color-border) 32px);
    opacity: 0.6;
  }
  .center { text-align: center; }
  .slide-container h2 .section-number {
    display: inline-block;
    background-color: var(--color-accent);
    color: #fff;
    font-weight: 700;
    border-radius: 999px;
    padding: 0 .55em;
    margin-right: .4em;
  }

  .overview {
    font-size: .8em;
    max-width: none;
  }
  .overview .slide {
    min-height: unset;
    scroll-snap-align: unset;
  }
  .overview .slide-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-evenly;
  }
  .overview .slide-container .slide {
    width: var(--slide-width);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    margin-bottom: 0.6em;
  }
  .mirrored { transform: scale(-1, 1); }
  .spacer { height: 50vh; }
  .overview .timer, .overview .spacer { display: none; }
  .overview .footnotes { position: unset; }
  html:fullscreen::-webkit-scrollbar { display: none; }
  html:fullscreen {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  html:fullscreen body { background-color: var(--color-bg); }

  @media (min-width: 992px) {
    :root { --slide-width: 49%; }
    body { font-size: 2em; }
    .slide {
      min-height: 100vh;
      scroll-snap-align: start;
    }
    li li { font-size: .9em; }
    .footnotes {
      position: absolute;
      bottom: 1em;
      font-size: .8em;
    }
  }
  @media (min-width: 1400px) {
    :root { --slide-width: 33%; }
  }
  @media (min-width: 1800px) {
    :root { --slide-width: 24.67%; }
  }
  @media print, (max-width: 991.98px) {
    .timer, .spacer { display: none; }
  }
  </style>

  <link rel="stylesheet" href=
  "https://cdn.jsdelivr.net/combine/npm/@xiee/utils/css/key-buttons.min.css,npm/@xiee/utils/css/heading-anchor.min.css"
  type="text/css">
  <script src="https://polyfill.io/v3/polyfill.min.js?features=es6"></script>
  <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
</head>

<body>
<?theme body?>
<script type="text/javascript">
(function(d) {
    let p = d.body;  // container of slides; assume <body> for now
    const s1 = ':scope > hr:not([class])', s2 = ':scope > h2';
    // find a container that has at least n "slides"
    function findContainer(s, n = 1) {
    if (p.querySelectorAll(s).length >= n) return true;
    // if body doesn't contain headings or <hr>s, look into children
    for (let i = 0; i < p.children.length; i++) {
      if (p.children[i].querySelectorAll(s).length >= n) {
        p = p.children[i]; break;
      }
    }
    return false;
    }
    function newEl(tag, cls) {
    const el = d.createElement(tag);
    if (cls) el.className = cls;
    return el;
    }
    if (!findContainer(s1, 3)) {
    // if not enough <hr>s found in children; look for <h2> instead
    if (p.tagName === 'BODY') {
      // not enough h2 found, this page is not appropriate for slides
      if (!findContainer(s2) && p.tagName === 'BODY') return;
      p.querySelectorAll(s2).forEach(h2 => h2.before(newEl('hr')));
    }
    }
    p.classList.add('slide-container');
    // add 'slide' class to the frontmatter div and toc
    ['.frontmatter', '#TOC'].forEach(s => {
    d.body.querySelector(s)?.classList.add('slide');
    });

    function newSlide(s) {
    return (s?.innerText === '') ? s : newEl('div', 'slide');
    }
    function isSep(el) {
    return el.tagName === 'HR' && el.attributes.length === 0;
    }
    let el = p.firstElementChild; if (isSep(el)) el.remove();
    el = p.firstElementChild; if (!el) return;
    let s = newSlide(); el.before(s);
    while (true) {
    let el = s.nextSibling;
    if (!el) break;
    // remove slide separators (<hr>) and create new slide
    if (isSep(el)) {
      s = newSlide(s);
      el.before(s); el.remove();
    } else if (el.classList?.contains('slide')) {
      s = newSlide(s);
      el.after(s);
    } else {
      s.append(el);
    }
    }
    function setAttr(el, attr) {
    const m = newEl('div');
    m.innerHTML = `<div ${attr}><\/div>`;
    const attrs = m.firstElementChild.attributes;
    for (let i = 0; i < attrs.length; i++) {
      let a = attrs[i];
      el.setAttribute(a.name, a.value);
    }
    m.remove();
    }
    const slides = d.querySelectorAll('div.slide'), N = slides.length,
        tm = d.querySelector('span.timer'), fn = d.querySelector('.footnotes');
    slides.forEach((s, i) => {
    // append footnotes
    if (fn) s.querySelectorAll('.footnote-ref > a[href^="#fn"]').forEach(a => {
      const li = fn.querySelector('li' + a.getAttribute('href'));
      if (!li) return;
      let f = s.querySelector('section.footnotes');
      if (!f) {
        f = newEl('section', 'footnotes'); s.append(f);
      }
      f.append(li);
      li.firstElementChild?.insertAdjacentHTML('afterbegin', `[${a.innerHTML}] `);
      li.outerHTML = li.innerHTML;
    });
    // add a timer
    s.append(tm ? tm.cloneNode() : newEl('span', 'timer'));
    // add page numbers
    const n = newEl('span', 'page-number');
    n.innerText = i + 1 + '/' + N;
    n.onclick = e => location.hash = i + 1;
    s.append(n);
    // apply slide attributes in <!--# -->
    for (let k in s.childNodes) {
      const node = s.childNodes[k];
      if (node.nodeType !== Node.COMMENT_NODE) continue;
      let t = node.textContent;
      if (!/^#/.test(t)) continue;
      t = t.replace(/^#/, '');
      const r = /[\s\n]class="([^"]+)"/, m = t.match(r);
      if (m) {
        t = t.replace(r, '').trim();
        s.className += ' ' + m[1];
      }
      if (t) setAttr(s, t);
      break;
    }
    s.classList.contains('extend') && s.append(newEl('div', 'spacer fade'));
    location.hash === ('#' + (i + 1)) && s.scrollIntoView();
    s.addEventListener('click', e => {
      if (!e.altKey) return;
      d.body.classList.toggle('overview');
      setTimeout(() => e.target.scrollIntoView(), 100);
    });
    });
    [...d.querySelectorAll('a.footnote-backref'), fn, tm].forEach(el => el?.remove());
    const tms = d.querySelectorAll('span.timer'), t1 = 1000 * tms[0].dataset.total;
    let t0;
    function startTimers() {
    t0 = new Date();
    setInterval(setTimers, 1000);
    }
    function setTimers() {
    let t = (new Date() - t0);
    if (t1) t = t1 - t;
    const t2 = new Date(Math.abs(t)).toISOString().substr(11, 8).replace(/^00:/, '');
    tms.forEach(el => {
      el.innerText = t2;
      if (t < 0) el.style.display = el.style.display === 'none' ? '' : 'none';
    });
    }
    // press f for fullscreen mode
    d.addEventListener('keyup', (e) => {
    if (e.target !== d.body) return;
    e.key === 'f' && d.documentElement.requestFullscreen();
    e.key === 'o' && d.body.classList.toggle('overview');
    e.key === 'm' && d.body.classList.toggle('mirrored');
    sessionStorage.setItem('body-class', d.body.className);
    });
    // start timer on fullscreen
    d.onfullscreenchange = (e) => d.fullscreenElement && !t0 && startTimers();
    tms.forEach(el => el.addEventListener('click', e => startTimers()));
    // restore previsouly saved body class
    const bc = sessionStorage.getItem('body-class');
    if (bc) d.body.className += ' ' + bc;
    })(document);
    </script>
    <script src=
    "https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-core.min.js"
    defer type="text/javascript">
    </script>
    <script src=
    "https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/autoloader/prism-autoloader.min.js"
    defer type="text/javascript">
    </script>

    <script src=
    "https://cdn.jsdelivr.net/combine/npm/@xiee/utils/js/key-buttons.min.js,npm/@xiee/utils/js/external-link.min.js,npm/@xiee/utils/js/heading-anchor.min.js"
    defer type="text/javascript">
    </script>
</body>
</html>
